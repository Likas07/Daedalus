{
	"name": "daedalus-monorepo",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"dev": "bun --cwd=packages/coding-agent src/cli.ts",
		"build:binary": "bun --cwd=packages/coding-agent run build:binary",
		"test": "bun run --workspaces --if-present --parallel test",
		"check": "biome check . && bun --cwd=packages/agent run check && bun --cwd=packages/ai run check && bun --cwd=packages/tui run check && bun --cwd=packages/coding-agent run check",
		"lint": "biome lint .",
		"fmt": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4",
		"@types/bun": "^1.3",
		"@typescript/native-preview": "^7.0.0-dev.20260302.1",
		"vitest": "4.1.4"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.41",
		"get-east-asian-width": "^1.4.0"
	}
}
