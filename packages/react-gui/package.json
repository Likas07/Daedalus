{
	"name": "@daedalus-pi/react-gui",
	"version": "0.1.0",
	"description": "React/Vite application shell for the Daedalus GUI",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "vite build",
		"check": "tsgo -p tsconfig.json",
		"dev": "vite --host 127.0.0.1",
		"test": "bun test --conditions browser src/App.test.tsx src/import-boundary.test.ts",
		"test:e2e": "bun test --conditions browser test/e2e/react-gui-smoke.test.ts"
	},
	"dependencies": {
		"@daedalus-pi/app-server-client": "workspace:*",
		"@daedalus-pi/app-server-protocol": "workspace:*",
		"@daedalus-pi/gui-components": "workspace:*",
		"@daedalus-pi/gui-core": "workspace:*",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@types/bun": "^1.3",
		"vite": "^7.2.6"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
