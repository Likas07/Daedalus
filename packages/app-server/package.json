{
	"name": "@daedalus-pi/app-server",
	"version": "0.1.0",
	"description": "Bun runtime app-server for the Daedalus GUI",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./server/main": {
			"types": "./src/server/main.ts",
			"import": "./src/server/main.ts"
		}
	},
	"bin": {
		"daedalus-app-server": "./src/server/main.ts"
	},
	"scripts": {
		"check": "tsgo -p tsconfig.json",
		"test": "bun test"
	},
	"dependencies": {
		"@daedalus-pi/agent-core": "workspace:*",
		"@daedalus-pi/app-server-protocol": "workspace:*",
		"@daedalus-pi/coding-agent": "workspace:*",
		"node-pty": "^1.1.0-beta9"
	},
	"devDependencies": {
		"@types/bun": "^1.3"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
