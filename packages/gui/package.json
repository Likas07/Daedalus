{
	"name": "@daedalus-pi/gui",
	"version": "0.1.0",
	"description": "Vite renderer UI for the Daedalus desktop GUI",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json && tsgo -p tsconfig.json",
		"dev": "bun src/dev.ts",
		"test": "bun test --conditions browser"
	},
	"dependencies": {
		"@daedalus-pi/app-server-client": "workspace:*",
		"@daedalus-pi/app-server-protocol": "workspace:*",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/svelte": "^5.0.0",
		"@types/bun": "^1.3",
		"happy-dom": "^20.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"vite": "^7.2.6"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
