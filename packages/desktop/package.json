{
	"name": "@daedalus-pi/desktop",
	"version": "0.1.0",
	"description": "Electron host shell for the Daedalus GUI",
	"type": "module",
	"main": "./.daedalus/desktop-dev/main.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build:dev": "bun build src/main.ts src/preload.ts --outdir .daedalus/desktop-dev --target node --format esm --external electron --sourcemap=external",
		"check": "tsgo -p tsconfig.json",
		"dev": "bun src/dev.ts",
		"test": "bun test",
		"start": "bun run build:dev && DAEDALUS_PROJECT_ROOT=../.. electron ."
	},
	"dependencies": {
		"@daedalus-pi/app-server": "workspace:*",
		"@daedalus-pi/app-server-client": "workspace:*",
		"@daedalus-pi/app-server-protocol": "workspace:*",
		"@daedalus-pi/gui": "workspace:*",
		"electron": "^40.6.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
