{
	"name": "@daedalus-pi/coding-agent",
	"version": "0.1.0",
	"description": "Coding agent CLI with read, bash, edit, write tools and session management",
	"type": "module",
	"daedalusConfig": {
		"name": "daedalus",
		"configDir": ".daedalus"
	},
	"bin": {
		"daedalus": "src/cli.ts",
		"dae": "src/cli.ts"
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./hooks": {
			"types": "./src/core/hooks/index.ts",
			"import": "./src/core/hooks/index.ts"
		}
	},
	"scripts": {
		"check": "tsgo -p tsconfig.json",
		"test": "bun test",
		"generate-template": "bun scripts/generate-template.ts",
		"build:binary": "bun run generate-template && bun build --compile --external mupdf --root ../.. ./src/bun/cli.ts --outfile dist/daedalus"
	},
	"dependencies": {
		"@mariozechner/jiti": "^2.6.2",
		"@daedalus-pi/agent-core": "workspace:*",
		"@daedalus-pi/ai": "workspace:*",
		"@daedalus-pi/tui": "workspace:*",
		"@silvia-odwyer/photon-node": "^0.3.4",
		"ajv": "^8.17.1",
		"chalk": "^5.5.0",
		"cli-highlight": "^2.1.11",
		"diff": "^8.0.2",
		"extract-zip": "^2.0.1",
		"file-type": "^21.1.1",
		"glob": "^13.0.1",
		"hosted-git-info": "^9.0.2",
		"ignore": "^7.0.5",
		"marked": "^15.0.12",
		"minimatch": "^10.2.3",
		"proper-lockfile": "^4.1.2",
		"strip-ansi": "^7.1.0",
		"undici": "^7.19.1",
		"yaml": "^2.8.2"
	},
	"overrides": {
		"rimraf": "6.1.2",
		"gaxios": {
			"rimraf": "6.1.2"
		}
	},
	"optionalDependencies": {
		"@mariozechner/clipboard": "^0.3.2"
	},
	"devDependencies": {
		"@types/bun": "^1.3",
		"@types/diff": "^7.0.2",
		"@types/hosted-git-info": "^3.0.5",
		"@types/ms": "^2.1.0",
		"@types/proper-lockfile": "^4.1.4"
	},
	"keywords": [
		"coding-agent",
		"ai",
		"llm",
		"cli",
		"tui",
		"agent"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Likas07/Daedalus.git",
		"directory": "packages/coding-agent"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
