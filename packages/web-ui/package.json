{
	"name": "@daedalus-pi/web-ui",
	"version": "0.1.0",
	"description": "Reusable web UI components for AI chat interfaces powered by @daedalus-pi/ai",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./app.css": "./dist/app.css"
	},
	"scripts": {
		"check": "tsgo -p tsconfig.json",
		"build:css": "tailwindcss -i ./src/app.css -o ./dist/app.css --minify"
	},
	"dependencies": {
		"@lmstudio/sdk": "^1.5.0",
		"@daedalus-pi/ai": "workspace:*",
		"@daedalus-pi/tui": "workspace:*",
		"docx-preview": "^0.3.7",
		"jszip": "^3.10.1",
		"lucide": "^0.544.0",
		"ollama": "^0.6.0",
		"pdfjs-dist": "5.4.394",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	},
	"peerDependencies": {
		"@mariozechner/mini-lit": "^0.2.0",
		"lit": "^3.3.1"
	},
	"devDependencies": {
		"@types/bun": "^1.3",
		"@mariozechner/mini-lit": "^0.2.0",
		"@tailwindcss/cli": "^4.0.0-beta.14"
	},
	"keywords": [
		"ai",
		"chat",
		"ui",
		"components",
		"llm",
		"web-components",
		"mini-lit"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Likas07/Daedalus.git",
		"directory": "packages/web-ui"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
